# Example Environment Configuration for Osdag Backend
# Copy this file to .env and fill in the values below.

# Django Security
SECRET_KEY=django-insecure-example-key-replace-in-production
DEBUG=True

# Allowed Hosts & CORS
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Note: DB is configured to use the included db.sqlite3 as requested in task requirements.
